# Chave de API do Google AI Studio (Gemini Pro + text-embedding-004)
# Obtenha em: https://aistudio.google.com/app/apikey
# NUNCA commitar este arquivo preenchido. Copie para `.env` (gitignored) e preencha localmente.
GOOGLE_API_KEY=cole-sua-chave-aqui

# Diretorio onde o ChromaDB persistira a colecao (deve estar no .gitignore)
# Padrao: ./chroma_db
CHROMA_PERSIST_DIR=./chroma_db

# Nome da colecao do ChromaDB
# Padrao: perfis_connect_ai
CHROMA_COLLECTION=perfis_connect_ai
